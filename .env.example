# The Guard — safe-by-default runtime controls

# Database (required for runners)
# IMPORTANT: do not paste real credentials here.
# Example format:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/the_guard?schema=public"
DATABASE_URL=""

# -----------------------------------------------------------------------------
# Demo mode (stable Loom demos; no live provider calls)
# -----------------------------------------------------------------------------
ENABLE_DEMO_MODE=true
# Path to deterministic demo snapshots (used by DemoDataProvider)
DEMO_SNAPSHOT_PATH="reports/demo/demo-snapshots.json"

# -----------------------------------------------------------------------------
# Cost protection
# -----------------------------------------------------------------------------
MAX_RUN_COST_USD=1.00
MAX_DAILY_COST_USD=5.00

# -----------------------------------------------------------------------------
# Run size + concurrency protection
# -----------------------------------------------------------------------------
MAX_CASES_PER_RUN=10
MAX_PARALLEL_EVALS=2

# -----------------------------------------------------------------------------
# Token protection (approximate tokenization; enforced pre-call)
# -----------------------------------------------------------------------------
MAX_INPUT_TOKENS=2000
MAX_OUTPUT_TOKENS=250

# -----------------------------------------------------------------------------
# Provider/model policy
# -----------------------------------------------------------------------------
# Comma-separated allowlist of safe-by-default models for dev/demo/CI.
SAFE_MODELS="gpt-4o-mini,gemini-1.5-flash"

# -----------------------------------------------------------------------------
# Retry safety
# -----------------------------------------------------------------------------
# Disable retries by default in demo mode.
THE_GUARD_MAX_RETRIES=0

# -----------------------------------------------------------------------------
# Benchmark sweep protection
# -----------------------------------------------------------------------------
ENABLE_BENCHMARK_SWEEPS=false

# -----------------------------------------------------------------------------
# Provider selection (used by apps/runner)
# -----------------------------------------------------------------------------
THE_GUARD_PROVIDER="openai"  # openai | google
THE_GUARD_MODEL="gpt-4o-mini"
# Provider keys (leave empty in examples; set in your shell or local .env files)
OPENAI_API_KEY=""
GEMINI_API_KEY=""
THE_GUARD_TIMEOUT_MS=30000

