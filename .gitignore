# The Guard (monorepo) — gitignore

###############################################################################
# Secrets / env
###############################################################################
.env
.env.*
.env.local
!.env.example
!apps/api/.env.example

###############################################################################
# Node / package managers
###############################################################################
node_modules/
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# PnP / Yarn (in case contributors use it)
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

###############################################################################
# Build outputs
###############################################################################
dist/
build/
out/

# Turbo
.turbo/

###############################################################################
# Next.js
###############################################################################
.next/

###############################################################################
# TypeScript
###############################################################################
*.tsbuildinfo

###############################################################################
# Prisma
###############################################################################
# Local sqlite dbs (if ever used)
*.db
*.db-journal

###############################################################################
# Reports / artifacts
###############################################################################
# Ignore temp outputs, keep deterministic demo snapshots checked in.
reports/*
!reports/demo/
!reports/demo/**
reports/tmp/

###############################################################################
# Logs
###############################################################################
logs/
*.log

###############################################################################
# Coverage
###############################################################################
coverage/

###############################################################################
# pnpm lockfile backups
###############################################################################
pnpm-lock.yaml.*

###############################################################################
# OS / editors
###############################################################################
.DS_Store
Thumbs.db
.vscode/
.idea/

